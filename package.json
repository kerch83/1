{
  "name": "decentralized-chat",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "bot": "npm run build --workspace @decentralized-chat/bot && node packages/bot/dist/index.js",
    "typecheck": "npm run build --workspaces",
    "webapp": "npm run build --workspace @decentralized-chat/webapp && npm run dev --workspace @decentralized-chat/webapp",
    "test": "npm run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
